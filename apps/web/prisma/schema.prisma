generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OPERATOR
  WAREHOUSE
  PURCHASER
}

enum OrderStatus {
  PENDING
  READY
  SHIPPED
  EXCEPTION
}

enum ShipmentStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  PARTIAL
  RECEIVED
  CANCELLED
}

enum MovementType {
  INITIAL
  PURCHASE_IN
  SALES_OUT
  ADJUST_IN
  ADJUST_OUT
}

enum InternalProductStatus {
  active
  inactive
}

enum SheinMappingStatus {
  pending
  active
  inactive
  conflict
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      Role
  createdAt DateTime @default(now())
  audits    AuditLog[]
}

model Warehouse {
  id        String @id @default(cuid())
  code      String @unique
  name      String
  active    Boolean @default(true)
  stocks    StockBalance[]
  shipments Shipment[]
  receipts  Receipt[]
  movements StockMovement[]
}

model Store {
  id        String   @id @default(cuid())
  name      String   @unique
  platform  String   @default("SHEIN")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sheinMappings SheinProductMapping[]
}

model ProductGroup {
  id          String   @id @default(cuid())
  groupCode   String   @unique
  nameCn      String
  nameEn      String?
  category    String?
  description String?
  imageUrl    String?
  status      InternalProductStatus @default(active)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products InternalProduct[]
}

model InternalProduct {
  id                     String   @id @default(cuid())
  internalSku            String   @unique
  productGroupId         String?
  productNameCn          String
  productNameEn          String?
  specification          String?
  color                  String?
  size                   String?
  model                  String?
  shippingName           String?
  description            String?
  imageUrl               String?
  supplierUrl            String?
  purchaseLeadDays       Int?
  declaredValue          Decimal? @db.Decimal(18, 4)
  declaredCurrency       String?
  weightGram             Decimal? @db.Decimal(12, 3)
  lengthCm               Decimal? @db.Decimal(10, 2)
  widthCm                Decimal? @db.Decimal(10, 2)
  heightCm               Decimal? @db.Decimal(10, 2)
  hsCode                 String?
  originCountry          String?
  hasBattery             Boolean  @default(false)
  isSensitiveCargo       Boolean  @default(false)
  defaultWarningQuantity Int      @default(0)
  status                 InternalProductStatus @default(active)
  source                 String   @default("manual")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  productGroup ProductGroup? @relation(fields: [productGroupId], references: [id])
  sheinMappings SheinProductMapping[]
}

model SheinProductMapping {
  id               String   @id @default(cuid())
  platform         String   @default("SHEIN")
  storeId          String
  internalProductId String?
  platformSkc      String   @unique
  platformSku      String?
  platformSpu      String?
  sheinProductId   String?
  sellerSku        String?
  sheinProductName String?
  status           SheinMappingStatus @default(active)
  remark           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  store           Store @relation(fields: [storeId], references: [id])
  internalProduct InternalProduct? @relation(fields: [internalProductId], references: [id])

  @@index([storeId])
  @@index([internalProductId])
  @@index([storeId, internalProductId, status])
}

model Product {
  id        String @id @default(cuid())
  name      String
  spu       String?
  skus      Sku[]
}

model Sku {
  id             String @id @default(cuid())
  code           String @unique
  sellerSku      String @unique
  platformSku    String?
  platformSkc    String?
  specification  String?
  supplier       String?
  purchasePrice  Decimal? @db.Decimal(12, 2)
  leadTimeDays   Int @default(15)
  safetyDays     Int @default(7)
  safetyStock    Int @default(0)
  productId      String
  product        Product @relation(fields: [productId], references: [id])
  orderLines     OrderLine[]
  stocks         StockBalance[]
  movements      StockMovement[]
  purchaseLines  PurchaseLine[]
}

model ImportJob {
  id          String @id @default(cuid())
  filename    String
  totalRows   Int
  successRows Int
  errorRows   Int
  createdAt   DateTime @default(now())
}

model Order {
  id             String @id @default(cuid())
  platform       String @default("SHEIN")
  orderNo        String @unique
  createdAt      DateTime
  shipBy         DateTime?
  country        String?
  currency       String?
  warehouseId    String?
  status         OrderStatus @default(PENDING)
  lines          OrderLine[]
}

model OrderLine {
  id          String @id @default(cuid())
  orderId     String
  skuId       String?
  sellerSku   String
  platformSku String?
  productName String
  spec        String?
  quantity    Int @default(1)
  price       Decimal? @db.Decimal(12, 2)
  order       Order @relation(fields: [orderId], references: [id])
  sku         Sku? @relation(fields: [skuId], references: [id])
  @@unique([orderId, sellerSku])
}

model Shipment {
  id          String @id @default(cuid())
  shipmentNo  String @unique
  warehouseId String
  status      ShipmentStatus @default(DRAFT)
  confirmedAt DateTime?
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  lines       ShipmentLine[]
  createdAt   DateTime @default(now())
}

model ShipmentLine {
  id         String @id @default(cuid())
  shipmentId String
  orderNo    String
  skuId      String
  quantity   Int
  shipment   Shipment @relation(fields: [shipmentId], references: [id])
}

model StockBalance {
  id          String @id @default(cuid())
  warehouseId String
  skuId       String
  quantity    Int @default(0)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  sku         Sku @relation(fields: [skuId], references: [id])
  @@unique([warehouseId, skuId])
}

model StockMovement {
  id          String @id @default(cuid())
  warehouseId String
  skuId       String
  type        MovementType
  quantity    Int
  referenceNo String
  reason      String?
  createdAt   DateTime @default(now())
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  sku         Sku @relation(fields: [skuId], references: [id])
}

model PurchaseOrder {
  id              String @id @default(cuid())
  purchaseNo      String @unique
  supplier        String
  expectedAt      DateTime?
  status          PurchaseStatus @default(DRAFT)
  lines           PurchaseLine[]
  logistics       LogisticsBatch[]
  receipts        Receipt[]
  createdAt       DateTime @default(now())
}

model PurchaseLine {
  id              String @id @default(cuid())
  purchaseOrderId String
  skuId           String
  quantity        Int
  receivedQty     Int @default(0)
  unitPrice       Decimal? @db.Decimal(12, 2)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  sku             Sku @relation(fields: [skuId], references: [id])
}

model LogisticsBatch {
  id              String @id @default(cuid())
  purchaseOrderId String
  carrier         String?
  domesticTrackNo String?
  internationalNo String?
  shippedAt       DateTime?
  expectedAt      DateTime?
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
}

model Receipt {
  id              String @id @default(cuid())
  receiptNo       String @unique
  purchaseOrderId String
  warehouseId     String
  receivedAt      DateTime @default(now())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])
  lines           ReceiptLine[]
}

model ReceiptLine {
  id          String @id @default(cuid())
  receiptId   String
  skuId       String
  acceptedQty Int
  rejectedQty Int @default(0)
  receipt     Receipt @relation(fields: [receiptId], references: [id])
}

model AuditLog {
  id        String @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  detail    Json?
  createdAt DateTime @default(now())
  user      User? @relation(fields: [userId], references: [id])
}
