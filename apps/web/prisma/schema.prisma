generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OPERATIONS
  LOGISTICS
}

enum Gender {
  MALE
  FEMALE
}

enum AppModule {
  productManagement
  storeManagement
  inventoryManagement
  orderManagement
  platformMappings
  warehouseManagement
  companyManagement
  userManagement
}

enum OrderStatus {
  PENDING
  READY
  SHIPPED
  EXCEPTION
}

enum ShipmentStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  PARTIAL
  RECEIVED
  CANCELLED
}

enum MovementType {
  INITIAL
  PURCHASE_IN
  SALES_OUT
  ADJUST_IN
  ADJUST_OUT
}

enum InternalProductStatus {
  active
  inactive
}

enum SheinMappingStatus {
  pending
  active
  inactive
  conflict
}

enum OrderLineMappingStatus {
  mapped
  unmapped
  excluded
}

model Company {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model User {
  id            String      @id @default(cuid())
  name          String
  email         String      @unique
  gender        Gender?
  idNumber      String?     @unique
  phone         String?
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role
  companyId     String?
  company       Company?    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  active        Boolean     @default(true)
  mustChangePassword Boolean @default(false)
  failedLoginAttempts Int    @default(0)
  loginFailureWindowStart DateTime?
  lockedUntil   DateTime?
  sessionVersion Int       @default(0)
  permissions   AppModule[] @default([])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  accounts      Account[]
  audits        AuditLog[]
  ownedStores   Store[]
  importJobs    ImportJob[]
  passwordResetTokens PasswordResetToken[]

  @@index([companyId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Warehouse {
  id        String @id @default(cuid())
  code      String @unique
  name      String
  active    Boolean @default(true)
  stocks    StockBalance[]
  shipments Shipment[]
  receipts  Receipt[]
  movements StockMovement[]
}

model Store {
  id        String   @id @default(cuid())
  name      String
  platform  String   @default("SHEIN")
  active    Boolean  @default(true)
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sheinMappings              SheinProductMapping[]
  orders                     Order[]
  productInventoryWarnings   StoreProductInventoryWarning[]

  @@unique([ownerId, name])
}

model InternalProduct {
  id           String   @id @default(cuid())
  internalSku  String   @unique
  companyName  String   @default("")
  attributes   Json     @default("[]")
  status       InternalProductStatus @default(active)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sheinMappings            SheinProductMapping[]
  storeInventoryWarnings   StoreProductInventoryWarning[]
}

model StoreProductInventoryWarning {
  id                String   @id @default(cuid())
  storeId           String
  internalProductId String
  warningQuantity   Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  store           Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  internalProduct InternalProduct @relation(fields: [internalProductId], references: [id], onDelete: Cascade)

  @@unique([storeId, internalProductId])
  @@index([storeId])
}

model SheinProductMapping {
  id               String   @id @default(cuid())
  platform         String   @default("SHEIN")
  storeId          String
  internalProductId String?
  platformSkc      String?
  platformSku      String?  @unique
  platformSpu      String?
  sheinProductId   String?
  sellerSku        String?  @unique
  sheinProductName String?
  status           SheinMappingStatus @default(active)
  remark           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  store           Store @relation(fields: [storeId], references: [id])
  internalProduct InternalProduct? @relation(fields: [internalProductId], references: [id])
  orderLines      OrderLine[]

  @@index([storeId])
  @@index([internalProductId])
  @@index([storeId, internalProductId, status])
}

model Product {
  id        String @id @default(cuid())
  name      String
  spu       String?
  skus      Sku[]
}

model Sku {
  id             String @id @default(cuid())
  code           String @unique
  sellerSku      String @unique
  platformSku    String?
  platformSkc    String?
  specification  String?
  supplier       String?
  purchasePrice  Decimal? @db.Decimal(12, 2)
  leadTimeDays   Int @default(15)
  safetyDays     Int @default(7)
  safetyStock    Int @default(0)
  productId      String
  product        Product @relation(fields: [productId], references: [id])
  orderLines     OrderLine[]
  stocks         StockBalance[]
  movements      StockMovement[]
  purchaseLines  PurchaseLine[]
}

model ImportJob {
  id          String @id @default(cuid())
  filename    String
  type        String @default("shein_order")
  totalRows   Int
  successRows Int
  errorRows   Int
  createdById String?
  createdAt   DateTime @default(now())
  createdBy   User? @relation(fields: [createdById], references: [id])
  orders      Order[]
}

model Order {
  id             String @id @default(cuid())
  platform       String @default("SHEIN")
  orderNo        String @unique
  createdAt      DateTime
  shipBy         DateTime?
  deliverBy      DateTime?
  country        String?
  currency       String?
  warehouseId    String?
  storeId        String?
  importJobId    String?
  status         OrderStatus @default(PENDING)
  platformStatus String?
  logisticsNo    String?
  logisticsCompany String?
  recipientName  String?
  recipientPhone String?
  recipientAddress String?
  recipientPostalCode String?
  store          Store? @relation(fields: [storeId], references: [id])
  importJob      ImportJob? @relation(fields: [importJobId], references: [id])
  lines          OrderLine[]

  @@index([storeId])
  @@index([importJobId])
}

model OrderLine {
  id              String @id @default(cuid())
  orderId         String
  skuId           String?
  sellerSku       String?
  platformSku     String
  platformSkc     String?
  platformSpu     String?
  productName     String
  spec            String?
  articleNo       String?
  quantity        Int @default(1)
  price           Decimal? @db.Decimal(12, 2)
  mappingStatus   OrderLineMappingStatus @default(unmapped)
  sheinMappingId  String?
  order           Order @relation(fields: [orderId], references: [id])
  sku             Sku? @relation(fields: [skuId], references: [id])
  sheinMapping    SheinProductMapping? @relation(fields: [sheinMappingId], references: [id])
  @@unique([orderId, platformSku])
  @@index([platformSku, mappingStatus])
  @@index([sellerSku])
  @@index([platformSkc])
  @@index([sheinMappingId])
}

model Shipment {
  id          String @id @default(cuid())
  shipmentNo  String @unique
  warehouseId String
  status      ShipmentStatus @default(DRAFT)
  confirmedAt DateTime?
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  lines       ShipmentLine[]
  createdAt   DateTime @default(now())
}

model ShipmentLine {
  id         String @id @default(cuid())
  shipmentId String
  orderNo    String
  skuId      String
  quantity   Int
  shipment   Shipment @relation(fields: [shipmentId], references: [id])
}

model StockBalance {
  id          String @id @default(cuid())
  warehouseId String
  skuId       String
  quantity    Int @default(0)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  sku         Sku @relation(fields: [skuId], references: [id])
  @@unique([warehouseId, skuId])
}

model StockMovement {
  id          String @id @default(cuid())
  warehouseId String
  skuId       String
  type        MovementType
  quantity    Int
  referenceNo String
  reason      String?
  createdAt   DateTime @default(now())
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  sku         Sku @relation(fields: [skuId], references: [id])
}

model PurchaseOrder {
  id              String @id @default(cuid())
  purchaseNo      String @unique
  supplier        String
  expectedAt      DateTime?
  status          PurchaseStatus @default(DRAFT)
  lines           PurchaseLine[]
  logistics       LogisticsBatch[]
  receipts        Receipt[]
  createdAt       DateTime @default(now())
}

model PurchaseLine {
  id              String @id @default(cuid())
  purchaseOrderId String
  skuId           String
  quantity        Int
  receivedQty     Int @default(0)
  unitPrice       Decimal? @db.Decimal(12, 2)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  sku             Sku @relation(fields: [skuId], references: [id])
}

model LogisticsBatch {
  id              String @id @default(cuid())
  purchaseOrderId String
  carrier         String?
  domesticTrackNo String?
  internationalNo String?
  shippedAt       DateTime?
  expectedAt      DateTime?
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
}

model Receipt {
  id              String @id @default(cuid())
  receiptNo       String @unique
  purchaseOrderId String
  warehouseId     String
  receivedAt      DateTime @default(now())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])
  lines           ReceiptLine[]
}

model ReceiptLine {
  id          String @id @default(cuid())
  receiptId   String
  skuId       String
  acceptedQty Int
  rejectedQty Int @default(0)
  receipt     Receipt @relation(fields: [receiptId], references: [id])
}

enum AuditSeverity {
  notice
  info
  warn
  critical
}

model AuditLog {
  id        String        @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  severity  AuditSeverity @default(info)
  detail    Json?
  createdAt DateTime      @default(now())
  user      User?         @relation(fields: [userId], references: [id])

  @@index([severity, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LoginCaptcha {
  id        String   @id @default(cuid())
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
