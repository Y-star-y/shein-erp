# Auth.js base URL — use LAN IP for internal access (e.g. http://192.168.1.100:3000)
# Used for OAuth callbacks and password-reset links when SMTP is not configured
AUTH_SECRET="replace-with-a-random-secret"
AUTH_URL="http://localhost:3000"

# Built-in super admin (created by pnpm db:seed)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-on-first-login"
ADMIN_NAME="超级管理员"

# Enterprise WeChat OAuth (optional — set NEXT_PUBLIC_WEWORK_ENABLED=true when configured)
WEWORK_CORP_ID=""
WEWORK_AGENT_ID=""
WEWORK_SECRET=""
NEXT_PUBLIC_WEWORK_ENABLED="false"

# Password reset: leave SMTP_HOST empty for intranet mode (link shown in UI + server terminal)
SMTP_HOST=""
